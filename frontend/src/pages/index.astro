---
// ── Isla interactiva: sólo el mapa se hidrata en el cliente ──────────────────
import BusMap from '../components/BusMap.jsx';

// ── Contenido estático: compilado en build time, sin JS extra ────────────────
const routes = [
  {
    id: 1,
    name: 'Ruta 1',
    schedule: '6:00 AM – 10:00 PM',
    stops: ['Entrada Principal', 'Biblioteca Central', 'Zona Rosa', 'Chapinero'],
    color: '#1565C0',
  },
  {
    id: 2,
    name: 'Ruta 2',
    schedule: '7:00 AM – 9:00 PM',
    stops: ['Campus Sur', 'Cafetería', 'Kennedy', 'Bosa Terminal'],
    color: '#0277BD',
  },
];

const announcements = [
  { date: '12 Apr', text: 'El Bus Ruta 1 saldrá con 10 min de retraso el viernes.' },
  { date: '10 Apr', text: 'Nuevo paradero habilitado frente a la biblioteca.' },
];
---

<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Monitoreo en tiempo real del transporte universitario" />
    <title>TrackUniversity · Transporte</title>
    <style>
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

      body {
        font-family: 'Segoe UI', system-ui, sans-serif;
        background: #f0f4f8;
        color: #1a202c;
      }

      /* ── Header ──────────────────────────────────────── */
      header {
        background: linear-gradient(135deg, #0d2b5e 0%, #1565C0 100%);
        color: white;
        padding: 1.5rem 2rem;
        display: flex;
        align-items: center;
        gap: 1rem;
        box-shadow: 0 2px 8px rgba(0,0,0,0.3);
      }
      header h1 { font-size: 1.6rem; font-weight: 700; }
      header p  { font-size: 0.9rem; opacity: 0.85; margin-top: 0.2rem; }

      /* ── Layout ──────────────────────────────────────── */
      main {
        max-width: 1200px;
        margin: 2rem auto;
        padding: 0 1.5rem;
        display: grid;
        grid-template-columns: 1fr 2fr;
        gap: 1.5rem;
      }
      @media (max-width: 768px) {
        main { grid-template-columns: 1fr; }
      }

      /* ── Sidebar ─────────────────────────────────────── */
      .sidebar { display: flex; flex-direction: column; gap: 1.5rem; }

      /* ── Cards ───────────────────────────────────────── */
      .card {
        background: white;
        border-radius: 12px;
        padding: 1.25rem 1.5rem;
        box-shadow: 0 1px 4px rgba(0,0,0,0.08);
      }
      .card h2 {
        font-size: 1rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        color: #0d2b5e;
        margin-bottom: 1rem;
        padding-bottom: 0.5rem;
        border-bottom: 2px solid #e2e8f0;
      }

      /* ── Route Cards ─────────────────────────────────── */
      .route-card {
        border-left: 4px solid var(--route-color, #1565C0);
        padding: 0.75rem 1rem;
        border-radius: 0 8px 8px 0;
        background: #f7fafc;
        margin-bottom: 0.75rem;
      }
      .route-card:last-child { margin-bottom: 0; }
      .route-card h3 { font-size: 1rem; font-weight: 600; color: #1a202c; }
      .route-card .schedule { font-size: 0.8rem; color: #718096; margin: 0.25rem 0 0.5rem; }
      .route-card ul { list-style: none; }
      .route-card ul li {
        font-size: 0.85rem;
        color: #4a5568;
        padding: 0.1rem 0;
      }
      .route-card ul li::before { content: '📍 '; }

      /* ── Announcements ───────────────────────────────── */
      .announcement {
        display: flex;
        gap: 0.75rem;
        padding: 0.5rem 0;
        border-bottom: 1px solid #e2e8f0;
        font-size: 0.875rem;
      }
      .announcement:last-child { border-bottom: none; }
      .announcement .date {
        font-weight: 600;
        color: #1565C0;
        white-space: nowrap;
      }

      /* ── Map section ─────────────────────────────────── */
      .map-section { display: flex; flex-direction: column; gap: 0; }
      .map-section .card { flex: 1; }
      .map-section .card h2 { margin-bottom: 0.75rem; }

      .live-badge {
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        font-size: 0.75rem;
        font-weight: 600;
        color: #38a169;
        background: #f0fff4;
        border: 1px solid #c6f6d5;
        border-radius: 999px;
        padding: 0.2rem 0.6rem;
        margin-left: 0.75rem;
        vertical-align: middle;
      }
      .live-badge::before {
        content: '';
        width: 8px;
        height: 8px;
        border-radius: 50%;
        background: #38a169;
        animation: pulse 1.5s infinite;
      }
      @keyframes pulse {
        0%, 100% { opacity: 1; }
        50%       { opacity: 0.3; }
      }
    </style>
  </head>

  <body>
    <header>
      <div>
        <h1>🚌 TrackUniversity</h1>
        <p>Monitoreo en tiempo real del transporte universitario</p>
      </div>
    </header>

    <main>
      <!-- ── Sidebar: contenido 100% estático (sin JS) ── -->
      <aside class="sidebar">

        <section class="card">
          <h2>Rutas Disponibles</h2>
          {routes.map(route => (
            <div class="route-card" style={`--route-color: ${route.color}`}>
              <h3>{route.name}</h3>
              <p class="schedule">🕐 {route.schedule}</p>
              <ul>
                {route.stops.map(stop => <li>{stop}</li>)}
              </ul>
            </div>
          ))}
        </section>

        <section class="card">
          <h2>Noticias del Campus</h2>
          {announcements.map(a => (
            <div class="announcement">
              <span class="date">{a.date}</span>
              <span>{a.text}</span>
            </div>
          ))}
        </section>

      </aside>

      <!-- ── Isla interactiva: sólo este componente carga JS en el cliente ── -->
      <section class="map-section">
        <div class="card">
          <h2>
            Mapa en Tiempo Real
            <span class="live-badge">EN VIVO</span>
          </h2>

          <!--
            client:load → Astro "isla": hidrata este componente React
            inmediatamente al cargar la página. El resto del HTML es
            HTML puro sin JavaScript.
          -->
          <BusMap client:load />
        </div>
      </section>
    </main>
  </body>
</html>
